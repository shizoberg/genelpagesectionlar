{% render 'ki-styles' %}

<section class="ki-story-strip" style="background: {{ section.settings.bg_color }};">
  <div class="ki-container">
    <div class="ki-ss-grid">
      {% for block in section.blocks %}
        <div class="ki-ss-card" style="background: {{ block.settings.bg }};" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.title | escape }}">
          {% endif %}
          <div class="ki-ss-text" style="color: {{ block.settings.fg }};">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .ki-story-strip { padding: 4rem 0; }
  .ki-ss-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  @media (min-width: 768px) { .ki-ss-grid { grid-template-columns: repeat(3, 1fr); gap: 1.25rem; } }
  .ki-ss-card { border-radius: 24px; overflow: hidden; }
  .ki-ss-card img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; }
  .ki-ss-text { padding: 1.25rem 1.5rem; }
  .ki-ss-text h3 { font-size: 1.125rem; font-weight: 800; margin-bottom: 0.375rem; }
  .ki-ss-text p { font-size: 0.875rem; opacity: 0.85; line-height: 1.5; }
</style>

{% schema %}
{
  "name": ".ki Story Strip",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Arka plan", "default": "#FFFFFF" }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Hikaye",
      "settings": [
        { "type": "image_picker", "id": "image",       "label": "Görsel" },
        { "type": "text",         "id": "title",       "label": "Başlık" },
        { "type": "textarea",     "id": "description", "label": "Açıklama" },
        { "type": "color",        "id": "bg",          "label": "Arka plan", "default": "#F5EFFB" },
        { "type": "color",        "id": "fg",          "label": "Metin",     "default": "#2A1F3D" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": ".ki Story Strip" }]
}
{% endschema %}
