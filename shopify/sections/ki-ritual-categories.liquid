{% render 'ki-styles' %}

<section class="ki-ritual-cats" style="background: {{ section.settings.bg_color }};">
  <div class="ki-container">
    <div class="ki-section-head">
      <h2 class="ki-heading">{{ section.settings.title }}</h2>
    </div>
    <div class="ki-rc-scroller">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="ki-rc-pill" style="background: {{ block.settings.bg }}; color: {{ block.settings.fg }};" {{ block.shopify_attributes }}>
          {{ block.settings.label }}
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .ki-ritual-cats { padding: 3rem 0; }
  .ki-section-head { text-align: center; margin-bottom: 1.5rem; }
  .ki-rc-scroller { display: flex; gap: 0.625rem; overflow-x: auto; padding: 0.5rem 0; scrollbar-width: none; }
  .ki-rc-scroller::-webkit-scrollbar { display: none; }
  .ki-rc-pill { display: inline-flex; align-items: center; padding: 0.625rem 1.25rem; border-radius: 9999px; font-size: 0.875rem; font-weight: 700; text-decoration: none; white-space: nowrap; flex-shrink: 0; }
</style>

{% schema %}
{
  "name": ".ki Ritual Categories",
  "tag": "section",
  "settings": [
    { "type": "text",  "id": "title",    "label": "Başlık",    "default": "Ritüellerine göre keşfet" },
    { "type": "color", "id": "bg_color", "label": "Arka plan", "default": "#FFFFFF" }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Etiket",
      "settings": [
        { "type": "text",  "id": "label", "label": "Etiket" },
        { "type": "url",   "id": "link",  "label": "Link" },
        { "type": "color", "id": "bg",    "label": "Arka plan", "default": "#F5EFFB" },
        { "type": "color", "id": "fg",    "label": "Metin",     "default": "#6B4E8C" }
      ]
    }
  ],
  "presets": [{ "name": ".ki Ritual Categories" }]
}
{% endschema %}
