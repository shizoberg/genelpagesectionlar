{% render 'ki-styles' %}

<section class="ki-manifesto" style="background: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="ki-container" style="max-width: 800px; text-align: center;">
    {% if section.settings.eyebrow != blank %}
      <p class="ki-eyebrow" style="color: {{ section.settings.text_color }}; opacity: 0.7;">{{ section.settings.eyebrow }}</p>
    {% endif %}
    <h2 style="font-size: clamp(1.75rem, 5vw, 2.75rem); font-weight: 800; line-height: 1.2; letter-spacing: -0.02em;">
      {{ section.settings.heading }}
    </h2>
    {% if section.settings.body != blank %}
      <div style="margin-top: 1.5rem; font-size: 1.05rem; line-height: 1.7; opacity: 0.85;">
        {{ section.settings.body }}
      </div>
    {% endif %}
    {% if section.settings.signature != blank %}
      <div style="margin-top: 2rem; font-style: italic; opacity: 0.7;">— {{ section.settings.signature }}</div>
    {% endif %}
  </div>
</section>

<style>
  .ki-manifesto { padding: 5rem 0; }
</style>

{% schema %}
{
  "name": ".ki Manifesto",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "eyebrow",    "label": "Üst etiket", "default": "MANİFESTO" },
    { "type": "text",     "id": "heading",    "label": "Manifesto",  "default": "Döngün, kendini dinleme zamanın." },
    { "type": "richtext", "id": "body",       "label": "Metin" },
    { "type": "text",     "id": "signature",  "label": "İmza" },
    { "type": "color",    "id": "bg_color",   "label": "Arka plan",  "default": "#2A1F3D" },
    { "type": "color",    "id": "text_color", "label": "Metin",      "default": "#FFFFFF" }
  ],
  "presets": [{ "name": ".ki Manifesto" }]
}
{% endschema %}
