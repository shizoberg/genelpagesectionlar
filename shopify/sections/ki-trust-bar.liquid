{% render 'ki-styles' %}

<section class="ki-trust-bar" style="background: {{ section.settings.bg_color }};">
  <div class="ki-container">
    <div class="ki-trust-grid">
      {% for block in section.blocks %}
        <div class="ki-trust-item" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <span class="ki-trust-icon">{{ block.settings.icon }}</span>
          {% endif %}
          <span class="ki-trust-text">{{ block.settings.text }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .ki-trust-bar { padding: 1.5rem 0; border-top: 1px solid var(--ki-border); border-bottom: 1px solid var(--ki-border); }
  .ki-trust-grid { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 1rem 2.5rem; }
  .ki-trust-item { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: var(--ki-foreground); font-weight: 600; }
  .ki-trust-icon { font-size: 1.125rem; }
</style>

{% schema %}
{
  "name": ".ki Trust Bar",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Arka plan", "default": "#FAF7FB" }
  ],
  "blocks": [
    {
      "type": "trust",
      "name": "Güven öğesi",
      "settings": [
        { "type": "text", "id": "icon", "label": "İkon (emoji)", "default": "✓" },
        { "type": "text", "id": "text", "label": "Metin",        "default": "Eczacı onaylı" }
      ]
    }
  ],
  "presets": [
    {
      "name": ".ki Trust Bar",
      "blocks": [
        { "type": "trust", "settings": { "icon": "🌱",  "text": "%100 Vegan" } },
        { "type": "trust", "settings": { "icon": "🔬",  "text": "Klinik dozaj" } },
        { "type": "trust", "settings": { "icon": "🚚",  "text": "Ücretsiz kargo" } },
        { "type": "trust", "settings": { "icon": "↩",  "text": "30 gün iade" } }
      ]
    }
  ]
}
{% endschema %}
